# z.ai Anthropic-compatible endpoint (primary LLM provider)
ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic/

# z.ai API key — used by @anthropic-ai/sdk for clause extraction, pillar mapping, etc.
ANTHROPIC_API_KEY=your_zai_key_here
ANTHROPIC_AUTH_TOKEN=your_zai_key_here

# Model to use
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# AgentRouter key — used by the claude CLI binary only
# (the claude CLI ignores ANTHROPIC_BASE_URL and routes internally via z.ai)
AGENTROUTER_API_KEY=your_agentrouter_key_here

# z.ai OpenAI-compatible fallback (GLM models)
ZAI_API_KEY=your_zai_openai_key_here
ZAI_MODEL=glm-5.1

# Tavily web search API key
TAVILY_API_KEY=

# pasal.id API token — Indonesian legal database (free, register at https://pasal.id/akun)
PASAL_API_TOKEN=

# Digital Policy Alert API key — regulatory event tracker for Pillar 6/7 (free demo, register at https://digitalpolicyalert.org/api-access)
DIGITAL_POLICY_ALERT_API_KEY=
