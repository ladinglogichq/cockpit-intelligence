        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        },
        "examples": {
          "ncn-based": {
            "value": "uksc/2024/123",
            "summary": "An older Neutral Citation Number-based document URI"
          },
          "uuid-based": {
            "value": "d-f11e093f-8a53-4e43-8dd8-1531b5d8f018",
